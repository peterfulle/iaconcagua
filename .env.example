# Copia este archivo a .env y completa tus valores.
ANTHROPIC_API_KEY=sk-ant-api03-...
MODEL=claude-opus-4-8
EFFORT=high
AGENT_NAME=Valentina
HEADLESS=true

# Vinculación por código de 8 dígitos (en vez de QR). Tu número, solo dígitos.
PAIR_NUMBER=56930093673

# Directorios de estado. En Render apúntalos a un disco persistente.
# AUTH_DIR=/data/auth_wa
# BROWSER_DATA_DIR=/data/.browser_data
# PORT=3000
GROUP_MODE=mention
GROUP_TRIGGERS=aconcagua,cotiza,cotización,departamento,depto,proyecto,valentina
ALLOWED_GROUPS=
TYPING_MIN_MS=900
TYPING_PER_CHAR_MS=32
TYPING_MAX_MS=6000
